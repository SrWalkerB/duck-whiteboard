# {$SITE_ADDRESS} vem do .env e define o que o Caddy escuta:
#   :80                     -> HTTP puro (padrão). Ideal atrás do Cloudflare,
#                              que cuida do HTTPS público.
#   duckboard.exemplo.com   -> HTTPS automático (Let's Encrypt) no próprio Caddy,
#                              caso um dia rode sem Cloudflare (precisa DNS + 80/443).
{$SITE_ADDRESS} {
	root * /srv
	encode zstd gzip

	# SPA: qualquer rota desconhecida cai no index.html (TanStack Router).
	try_files {path} /index.html
	file_server

	# Assets com hash no nome podem ser cacheados "para sempre".
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		# Esconde o header que revela o servidor.
		-Server
	}
}
