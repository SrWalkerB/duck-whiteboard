# Copie para .env e ajuste conforme o modo:  cp .env.example .env

# ============================================================
# Modo http (padrão) — ./deploy.sh   ou   ./deploy.sh http
# Serve HTTP direto na porta abaixo. Bom para local ou atrás de
# um proxy externo (Cloudflare, nginx, etc.).
# ============================================================
HTTP_PORT=8080
SITE_ADDRESS=:80

# ============================================================
# Modo tls — ./deploy.sh tls
# O próprio Caddy emite o certificado (Let's Encrypt).
# Requer domínio apontando pro servidor e portas 80/443 abertas.
# Dica: defina HTTP_PORT=80 acima neste modo.
# ============================================================
APP_DOMAIN=
HTTPS_PORT=443

# ============================================================
# Modo traefik — ./deploy.sh traefik
# Sem publicar porta; entra na rede do Traefik e usa labels.
# Ajuste conforme a config do SEU Traefik.
# ============================================================
PROXY_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
CERT_RESOLVER=le

# ============================================================
# Opcionais (todos os modos)
# ============================================================
# IMAGE=duck-whiteboard:latest
# CONTAINER_NAME=duckboard
